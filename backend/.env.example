APP_NAME="Admin Dashboard"
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://admin_dashboard_user:replace-with-password@localhost:5432/admin_dashboard
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-strong-admin-password
SESSION_SECRET=replace-with-a-long-random-secret
PRODUCT_SECRET_ENCRYPTION_KEY=replace-with-fernet-key-from-python
SESSION_COOKIE_NAME=admin_session
SESSION_EXPIRE_MINUTES=720
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TRUSTED_HOSTS=localhost,127.0.0.1
PRODUCT_API_ALLOWED_HOSTS=
PRODUCT_API_RESPONSE_SIZE_LIMIT_BYTES=1000000
